<!--
TRMNL Private Plugin Markup (Liquid)

Ce markup attend merge_variables avec la structure compacte produite juste avant sérialisation:
- t: traductions minimales
- w: météo
- f: marchés
- c: agenda
-->

<style>
  .daypulse-root span.title {
    font-size: 1.3rem !important;
    line-height: 1.1 !important;
  }

  .daypulse-root span.label {
    font-size: 1.1rem !important;
    line-height: 1.18 !important;
  }

  .daypulse-root span.label.label--small {
    font-size: 1.1rem !important;
  }

  .daypulse-root span.label.label--large {
    font-size: 1.3rem !important;
    line-height: 1.15 !important;
  }

  .daypulse-root td .label,
  .daypulse-root .grid .label,
  .daypulse-root .flex .label {
    font-size: inherit;
  }

  .daypulse-root .agenda-events .label {
    font-size: 0.98rem !important;
  }

  .daypulse-root .forecast-icon-row {
    position: relative;
    width: 100%;
    height: 3rem;
  }

  .daypulse-root .forecast-icon-group {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3rem;
    height: 3rem;
    transform: translate(-50%, -50%);
  }

  .daypulse-root .forecast-icon-group--solo {
    width: 1.8rem;
  }

  .daypulse-root .forecast-icon {
    position: absolute;
    top: 50%;
    left: 0;
    width: 2.1rem;
    height: 2.1rem;
    transform: translateY(-50%);
    display: block;
  }

  .daypulse-root .forecast-precip {
    position: absolute;
    top: 50%;
    left: 1.95rem;
    transform: translateY(-50%);
    line-height: 1;
    white-space: nowrap;
  }

  .daypulse-root .forecast-heading {
    display: block;
    line-height: 1.28 !important;
    padding-bottom: 0.25rem;
    overflow: visible;
  }

  .daypulse-root span.label.forecast-temp {
    font-size: 0.95rem !important;
    line-height: 1.05 !important;
  }
</style>

<div class="layout layout--col layout--top layout--stretch h--full daypulse-root" style="width:100%; height:100%;">
  <div class="flex flex--col gap h--full" style="width:100%; min-height:0;">
    <!-- Top half: Weather (left) + Markets (right) -->
    <div style="width:100%; flex:1 1 0; min-height:0;">
      <div class="grid grid--cols-2 gap h--full" style="width:100%; grid-template-columns:repeat(2, minmax(0, 1fr));">
        <!-- Weather -->
        <div class="flex flex--col gap--small label--outline p--4 h--full" style="width:100%; min-width:0; box-sizing:border-box;">
          <div class="flex flex--row flex--center-x flex--center-y" style="margin-top:-0.2rem;">
            <span class="title">{{ w.ci }}</span>
          </div>

          {% unless w.o %}
            <span class="label label--small label--gray">{{ t.du }}</span>
          {% endunless %}

          <div class="grid gap--small" style="width:100%; grid-template-columns:4.6rem minmax(0, 1fr) auto; align-items:center; column-gap:0.5rem;">
            <div class="flex flex--center-x flex--center-y" style="justify-content:flex-start; align-items:center; width:4.6rem;">
              {% assign current_icon_name = "wi-cloudy" %}
              {% case w.c.i %}
                {% when 0 %}{% assign current_icon_name = "wi-day-sunny" %}
                {% when 1 %}{% assign current_icon_name = "wi-day-cloudy" %}
                {% when 2 %}{% assign current_icon_name = "wi-cloudy" %}
                {% when 3 %}{% assign current_icon_name = "wi-fog" %}
                {% when 4 %}{% assign current_icon_name = "wi-sprinkle" %}
                {% when 5 %}{% assign current_icon_name = "wi-rain" %}
                {% when 6 %}{% assign current_icon_name = "wi-snow" %}
                {% when 7 %}{% assign current_icon_name = "wi-thunderstorm" %}
                {% when 8 %}{% assign current_icon_name = "wi-night-clear" %}
                {% when 9 %}{% assign current_icon_name = "wi-night-alt-cloudy" %}
                {% when 10 %}{% assign current_icon_name = "wi-night-fog" %}
                {% when 11 %}{% assign current_icon_name = "wi-night-alt-sprinkle" %}
                {% when 12 %}{% assign current_icon_name = "wi-night-alt-rain" %}
                {% when 13 %}{% assign current_icon_name = "wi-night-alt-snow" %}
                {% when 14 %}{% assign current_icon_name = "wi-night-alt-thunderstorm" %}
              {% endcase %}
              {% assign icon_url = "https://trmnl.com/images/plugins/weather/" | append: current_icon_name | append: ".svg" %}
              <img class="image image-dither w--20 h--20" src="{{ icon_url }}" alt="" style="width:4.95rem; height:4.95rem;" />
            </div>
            <div class="flex flex--center-x flex--center-y" style="justify-content:center; align-items:center; text-align:center; min-width:0;">
              <span class="value value--large value--tnums" style="font-size:3.35rem; line-height:1;">{{ w.c.td }}</span>
            </div>
            <div class="flex flex--col gap--xsmall" style="text-align:right; align-items:flex-end; justify-content:flex-end; min-width:8rem;">
              <span class="label label--underline" style="white-space: nowrap;">{{ t.h }} {{ w.c.h }}%</span>
              <span class="label label--underline flex flex--row" style="white-space: nowrap; width:100%; justify-content:flex-end; gap:0.35rem;">
                <span>{{ t.w }} {{ w.c.ws }} {{ w.c.wu }}</span>
                <span>{{ w.c.wd }}</span>
              </span>
            </div>
          </div>

          <div class="flex flex--row flex--center-x" style="width:100%; margin-top:0.15rem; align-items:center; justify-content:center; gap:3rem;">
            <div class="flex flex--row flex--center-y" style="align-items:center; gap:0.35rem;">
              <img class="image image-dither" src="https://trmnl.com/images/plugins/weather/wi-sunrise.svg" alt="" style="width:1.55rem; height:1.55rem;" />
              <span class="label label--gray" style="margin-top:0.3rem;">{{ t.sr }} {{ w.c.sr }}</span>
            </div>
            <div class="flex flex--row flex--center-y" style="align-items:center; gap:0.35rem;">
              {% assign moon_icon_name = "wi-moon-alt-new" %}
              {% case w.c.mi %}
                {% when 0 %}{% assign moon_icon_name = "wi-moon-alt-new" %}
                {% when 1 %}{% assign moon_icon_name = "wi-moon-alt-waxing-crescent-3" %}
                {% when 2 %}{% assign moon_icon_name = "wi-moon-alt-first-quarter" %}
                {% when 3 %}{% assign moon_icon_name = "wi-moon-alt-waxing-gibbous-3" %}
                {% when 4 %}{% assign moon_icon_name = "wi-moon-alt-full" %}
                {% when 5 %}{% assign moon_icon_name = "wi-moon-alt-waning-gibbous-3" %}
                {% when 6 %}{% assign moon_icon_name = "wi-moon-alt-third-quarter" %}
                {% when 7 %}{% assign moon_icon_name = "wi-moon-alt-waning-crescent-3" %}
              {% endcase %}
              {% assign moon_icon_url = "https://trmnl.com/images/plugins/weather/" | append: moon_icon_name | append: ".svg" %}
              <img class="image image-dither" src="{{ moon_icon_url }}" alt="" style="width:1.55rem; height:1.55rem;" />
              <span class="label label--gray" style="margin-top:0.3rem;">{{ t.ss }} {{ w.c.ss }}</span>
            </div>
          </div>

          <div class="flex flex--col gap--xsmall" style="width:100%; margin-top:0.3rem;">
            <span class="label label--gray forecast-heading" style="margin-top:0.05rem;">{{ t.fc }}</span>
            <div class="grid grid--cols-5 gap--xsmall" style="grid-template-columns:repeat(5, minmax(0, 1fr));">
              {% for day in w.f %}
                {% assign day_icon_name = "wi-cloudy" %}
                {% case day.i %}
                  {% when 0 %}{% assign day_icon_name = "wi-day-sunny" %}
                  {% when 1 %}{% assign day_icon_name = "wi-day-cloudy" %}
                  {% when 2 %}{% assign day_icon_name = "wi-cloudy" %}
                  {% when 3 %}{% assign day_icon_name = "wi-fog" %}
                  {% when 4 %}{% assign day_icon_name = "wi-sprinkle" %}
                  {% when 5 %}{% assign day_icon_name = "wi-rain" %}
                  {% when 6 %}{% assign day_icon_name = "wi-snow" %}
                  {% when 7 %}{% assign day_icon_name = "wi-thunderstorm" %}
                  {% when 8 %}{% assign day_icon_name = "wi-night-clear" %}
                  {% when 9 %}{% assign day_icon_name = "wi-night-alt-cloudy" %}
                  {% when 10 %}{% assign day_icon_name = "wi-night-fog" %}
                  {% when 11 %}{% assign day_icon_name = "wi-night-alt-sprinkle" %}
                  {% when 12 %}{% assign day_icon_name = "wi-night-alt-rain" %}
                  {% when 13 %}{% assign day_icon_name = "wi-night-alt-snow" %}
                  {% when 14 %}{% assign day_icon_name = "wi-night-alt-thunderstorm" %}
                {% endcase %}
                {% assign day_icon_url = "https://trmnl.com/images/plugins/weather/" | append: day_icon_name | append: ".svg" %}
                <div class="flex flex--col flex--center-x gap--xsmall">
                  <div class="forecast-icon-row">
                    <div class="forecast-icon-group{% if day.pp == blank or day.pp == "—" %} forecast-icon-group--solo{% endif %}">
                      <img class="image image-dither forecast-icon" src="{{ day_icon_url }}" alt="" />
                      {% unless day.pp == blank or day.pp == "—" %}
                        <span class="label label--small label--gray forecast-precip">{{ day.pp }}%</span>
                      {% endunless %}
                    </div>
                  </div>
                  <span class="label">{{ day.d }}</span>
                  <span class="label forecast-temp">{{ day.x }}°/{{ day.n }}°</span>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>

        <!-- Markets -->
        <div class="flex flex--col gap--small label--outline p--4 h--full" style="width:100%; min-width:0; box-sizing:border-box;">
          <div class="flex flex--col gap--small" style="margin-top:-0.3rem;">
            {% unless f.o %}
              <span class="label label--small label--gray">{{ t.du }}</span>
            {% endunless %}

            {% if f.i.size > 0 %}
                <table class="table table--xsmall" style="width:100%; table-layout:fixed; border-collapse:separate; border-spacing:0 0.12rem;">
                <tbody>
                  {% for idx in f.i %}
                    <tr>
                          <td style="width:41%; vertical-align:middle;"><span class="label" data-clamp="1">{{ idx.l }}</span></td>
                          <td style="width:32%; text-align:left; vertical-align:middle;"><span class="label label--gray" style="display:block; text-align:left;">{{ idx.p }}</span></td>
                          <td style="width:27%; text-align:left; vertical-align:middle;"><span class="label" style="display:block; text-align:left;">{{ idx.a }} {{ idx.c }}%</span></td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            {% else %}
              <span class="label label--small label--gray">—</span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom half: Google Calendar (50%) -->
    <div style="width:100%; flex:1 1 0; min-height:0;">
      <div class="flex flex--col gap--small label--outline p--4 h--full" style="width:100%; min-height:0; box-sizing:border-box;">
        <div class="grid grid--cols-7 gap--xsmall" style="width:100%; grid-template-columns:repeat(7, minmax(0, 1fr)); align-content:start; flex:0 0 auto;">
          {% for day in c.d %}
            <div class="flex flex--col gap--xsmall" style="min-width:0;">
              {% if day.w %}
                <span class="label label--inverted rounded--xsmall" style="display:flex; align-items:center; justify-content:center; height:1.45rem; line-height:1; padding:0 0.4rem; position:relative; top:-4px;"><span style="position:relative; top:2px; line-height:1;">{{ day.l }}</span></span>
              {% else %}
                <span class="label label--underline" style="line-height:1.45rem;">{{ day.l }}</span>
              {% endif %}
              {% if c.o %}
                <div style="{% if day.w %}margin-top:-6px;{% else %}margin-top:-3px;{% endif %}">
                  {% if day.e.size > 0 %}
                    <table class="table table--xsmall agenda-events" style="width:100%; table-layout:fixed;">
                      <tbody>
                        {% for ev in day.e %}
                          <tr>
                            <td style="width:100%; padding-top:0.22rem; padding-bottom:0.22rem; vertical-align:middle;">
                              <span class="label" style="display:block; white-space:normal; line-height:1.15; overflow-wrap:anywhere; word-break:break-all; text-align:justify;">{% if ev.t != blank %}{{ ev.t }} {% endif %}{{ ev.s }}</span>
                            </td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  {% else %}
                    <span class="label label--gray" style="display:block; margin-top:3px;">{{ t.ne }}</span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
        {% unless c.o %}
          <div class="flex flex--center-x flex--center-y h--full" style="width:100%; flex:1;">
            <span class="label label--large label--gray">{{ t.du }}</span>
          </div>
        {% endunless %}
      </div>
    </div>
  </div>
</div>
