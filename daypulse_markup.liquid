<!--
TRMNL Private Plugin Markup (Liquid)

Ce markup attend merge_variables avec la structure produite par le script Python du plugin:
- t: translations (labels)
- weather: current + forecast
- finance: indices
- calendar: days[7]
-->

<div class="layout layout--col layout--top layout--stretch" style="width:100%;">
  <div class="flex flex--col stretch-y" style="width:100%;">
    <!-- Top half: Weather (left) + Markets (right) -->
    <div class="pb--gap h--[50cqh]" style="width:100%;">
      <div class="grid grid--cols-2 gap h--full" style="width:100%; grid-template-columns:repeat(2, minmax(0, 1fr));">
        <!-- Weather -->
        <div class="flex flex--col gap--small outline p--4 h--full" style="width:100%; min-width:0; box-sizing:border-box;">
          <div class="flex flex--row flex--center-x flex--center-y" style="margin-top:-0.2rem;">
            <span class="title">{{ weather.city }}</span>
          </div>

          {% unless weather.ok %}
            <span class="label label--small label--gray">{{ t.data_unavailable }}</span>
          {% endunless %}

          <div class="grid gap--small" style="width:100%; grid-template-columns:4.6rem minmax(0, 1fr) auto; align-items:center; column-gap:0.5rem;">
            <div class="flex flex--center-x flex--center-y" style="justify-content:flex-start; align-items:center; width:4.6rem;">
              {% assign icon_url = "https://trmnl.com/images/plugins/weather/" | append: weather.current.icon | append: ".svg" %}
              <img class="image image-dither w--20 h--20" src="{{ icon_url }}" alt="" style="width:4.4rem; height:4.4rem;" />
            </div>
            <div class="flex flex--center-x flex--center-y" style="justify-content:center; align-items:center; text-align:center; min-width:0;">
              <span class="value value--large value--tnums" style="font-size:3rem; line-height:1;">{{ weather.current.temperature_display }}</span>
            </div>
            <div class="flex flex--col gap--xsmall" style="text-align:right; align-items:flex-end; justify-content:flex-end; min-width:8rem;">
              <span class="label label--underline" style="white-space: nowrap;">{{ t.humidity }} {{ weather.current.humidity }}%</span>
              <span class="label label--underline flex flex--row" style="white-space: nowrap; width:100%; justify-content:flex-end; gap:0.35rem;">
                <span>{{ t.wind }} {{ weather.current.wind_speed }} {{ weather.current.wind_speed_unit }}</span>
                <span>{{ weather.current.wind_direction }}</span>
              </span>
            </div>
          </div>

          <div class="flex flex--col gap--xsmall" style="width:100%; margin-top:0.3rem;">
            <span class="label label--gray" style="display:block; margin-top:0.15rem;">{{ t.forecast }}</span>
            <div class="grid grid--cols-3 gap--xsmall">
              {% for day in weather.forecast %}
                {% assign day_icon_url = "https://trmnl.com/images/plugins/weather/" | append: day.icon | append: ".svg" %}
                <div class="flex flex--col flex--center-x gap--xsmall">
                  <img class="image image-dither w--8 h--8" src="{{ day_icon_url }}" alt="" />
                  <span class="label">{{ day.day_label }}</span>
                  <span class="label">{{ day.temp_max }}°/{{ day.temp_min }}°</span>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>

        <!-- Markets -->
        <div class="flex flex--col gap--small outline p--4 h--full" style="width:100%; min-width:0; box-sizing:border-box;">
          {% unless finance.ok %}
            <span class="label label--small label--gray">{{ t.data_unavailable }}</span>
          {% endunless %}

          {% if finance.indices.size > 0 %}
            <table class="table table--xsmall" data-table-limit="true" style="width:100%; table-layout:fixed;">
              <tbody>
                {% for idx in finance.indices %}
                  <tr>
                    <td><span class="label" data-clamp="1">{{ idx.label }}</span></td>
                    <td><span class="label label--gray">{{ idx.price }}</span></td>
                    <td><span class="label">{{ idx.arrow }} {{ idx.change_percent }}%</span></td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <span class="label label--small label--gray">—</span>
          {% endif %}
        </div>
      </div>
    </div>

    <!-- Bottom half: Google Calendar (50%) -->
    <div class="pt--gap h--[50cqh]" style="width:100%;">
      <div class="flex flex--col gap--small outline p--4 h--full" style="width:100%; box-sizing:border-box;">
        <div class="grid grid--cols-7 gap--xsmall" style="width:100%; grid-template-columns:repeat(7, minmax(0, 1fr));">
          {% for day in calendar.days %}
            <div class="flex flex--col gap--xsmall" style="min-width:0;">
              {% if day.is_weekend %}
                <span class="label label--filled rounded--xsmall" style="display:flex; align-items:center; justify-content:center; height:1.3rem; line-height:1; padding:0 0.35rem;"><span style="position:relative; top:1.75px; line-height:1;">{{ day.day_label }}</span></span>
              {% else %}
                <span class="label label--underline" style="line-height:1.3rem;">{{ day.day_label }}</span>
              {% endif %}
              {% if calendar.ok %}
                {% if day.events.size > 0 %}
                  {% for ev in day.events %}
                    <span class="label" data-clamp="1">{{ ev.time_label }} {{ ev.summary }}</span>
                  {% endfor %}
                {% else %}
                  <span class="label label--gray">{{ t.no_events }}</span>
                {% endif %}
              {% endif %}
            </div>
          {% endfor %}
        </div>
        {% unless calendar.ok %}
          <div class="flex flex--center-x flex--center-y h--full" style="width:100%; flex:1;">
            <span class="label label--large label--gray">{{ t.data_unavailable }}</span>
          </div>
        {% endunless %}
      </div>
    </div>
  </div>
</div>
